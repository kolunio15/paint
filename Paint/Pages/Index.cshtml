@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome :)";
}

<main class="gallery">
    <div class="gallery-window">
        <!-- Pasek tytułowy okna -->
        <div class="gallery-titlebar">
            <div class="titlebar-title">Exploring - Paint Gallery</div>
            <div class="gallery-titlebar-buttons">
                <div class="titlebar-btn">_</div>
                <div class="titlebar-btn titlebar-btn-max"></div>
                <div class="titlebar-btn">✕</div>
            </div>
        </div>

        <!-- Siatka prac -->
        <section>
        @foreach (var artwork in Model.Artworks)
        {
            <article>
                <figure>
                    <a asp-page="/Artwork" asp-route-id="@artwork.Id">
                        <img src="@artwork.ImageUrl" alt="@artwork.Title">
                    </a>
                    <div>
                        <span class="gallery-art-title">@artwork.Title</span>
                        <div class="vote-controls">
                            <button>+</button>
                            <span class="vote-points @(artwork.Points < 0 ? "points-negative" : "points-positive")">@artwork.Points</span>
                            <button>-</button>
                        </div>
                    </div>
                </figure>
            </article>
        }
        </section>

        <!-- Pasek statusu -->
        <div class="gallery-statusbar">
            <span>@Model.Artworks.Count object(s)</span>
            <span>Ready</span>
        </div>
    </div>
</main>