<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="~/css/style.css">

    @RenderSection("Style", required: false)

    <title>@ViewBag.Title</title>
</head>
<body>
    <nav>
        <ul>
            <li><a asp-page="/Index"><img src="~/icons/homepage.ico" width="16" height="16" alt=""> Home</a></li>
            <li><a asp-page="/Rooms"><img src="~/icons/network_normal_two_pcs.ico" width="16" height="16" alt=""> Rooms</a></li>
            <li><a asp-page="/Canvas"><img src="~/icons/paint.ico" width="16" height="16" alt=""> Paint</a></li>
            <li><a asp-page="/Account"><img src="~/icons/users.ico" width="16" height="16" alt=""> Account</a></li>
        </ul>
    </nav>
    <div>
        @RenderBody()
    </div>
</body>
</html>